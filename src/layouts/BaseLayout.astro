---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Profound Book Club', description = 'A book club for deep thinkers.' } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
