import Conversations from '../components/Conversations.astro';
import PsaGrid from '../components/PsaGrid.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main id="top">
    <Hero />
    <CurrentBook />
    <Chronology />
    <Conversations />
    <PsaGrid />
    <Contact />
