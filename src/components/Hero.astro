---
import { site } from '../content/site';
---

<section class="hero">
  <div class="hero-text">
    <p class="hero-eyebrow">{site.heroEyebrow}</p>
    <h1 class="hero-title">The Profound <span class="italic">Book Club</span></h1>
    <p class="hero-tagline">{site.tagline}</p>
    <div class="hero-meta">
      {
        site.heroStats.map((stat) => (
          <div class="hero-meta-item">
            <span class:list={['num', { accent: stat.num === '∞' }]}>{stat.num}</span>
            {stat.label}
          </div>
        ))
      }
    </div>
  </div>
  <div class="hero-visual">
    <svg class="control-chart" viewBox="0 0 420 320" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="30" height="30" patternUnits="userSpaceOnUse">
          <path d="M30 0H0V30" fill="none" stroke="rgba(26,24,20,0.06)" stroke-width="0.5"></path>
        </pattern>
      </defs>
      <rect x="20" y="20" width="380" height="260" fill="url(#grid)"></rect>
      <rect
        x="20"
        y="20"
        width="380"
        height="260"
        fill="none"
        stroke="var(--rule)"
        stroke-width="0.6"></rect>
      <line
        x1="20"
        y1="60"
        x2="400"
        y2="60"
        stroke="var(--accent)"
        stroke-width="0.8"
        stroke-dasharray="4 4"
        opacity="0.6"></line>
      <line x1="20" y1="150" x2="400" y2="150" stroke="var(--ink-soft)" stroke-width="1"></line>
      <line
        x1="20"
        y1="240"
        x2="400"
        y2="240"
        stroke="var(--accent)"
        stroke-width="0.8"
        stroke-dasharray="4 4"
        opacity="0.6"></line>
      <text
        x="408"
        y="63"
        font-family="JetBrains Mono, monospace"
        font-size="9"
        fill="var(--ink-mute)">UCL</text
      >
      <text
        x="408"
        y="153"
        font-family="JetBrains Mono, monospace"
        font-size="9"
        fill="var(--ink-mute)">x̄</text
      >
      <text
        x="408"
        y="243"
        font-family="JetBrains Mono, monospace"
        font-size="9"
        fill="var(--ink-mute)">LCL</text
      >
      <path
        class="chart-process-line"
        d="M45,210 L75,185 L105,195 L135,170 L165,190 L195,158 L225,152 L255,128 L285,122 L315,45 L345,132 L375,102 L395,122"
        fill="none"
        stroke="var(--ink)"
        stroke-width="1.5"
        stroke-linejoin="round"></path>
      <circle
        class="chart-point"
        cx="45"
        cy="210"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 0.9s"></circle>
      <circle
        class="chart-point"
        cx="75"
        cy="185"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 1.02s"></circle>
      <circle
        class="chart-point"
        cx="105"
        cy="195"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 1.14s"></circle>
      <circle
        class="chart-point"
        cx="135"
        cy="170"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 1.26s"></circle>
      <circle
        class="chart-point"
        cx="165"
        cy="190"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 1.38s"></circle>
      <circle
        class="chart-point"
        cx="195"
        cy="158"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 1.5s"></circle>
      <circle
        class="chart-point"
        cx="225"
        cy="152"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 1.62s"></circle>
      <circle
        class="chart-point"
        cx="255"
        cy="128"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 1.74s"></circle>
      <circle
        class="chart-point"
        cx="285"
        cy="122"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 1.86s"></circle>
      <circle
        class="chart-point"
        cx="315"
        cy="45"
        r="6"
        fill="var(--accent)"
        stroke="var(--accent)"
        stroke-width="1.5"
        fill-opacity="0"
        style="animation-delay: 1.98s"></circle>
      <circle
        class="chart-point"
        cx="345"
        cy="132"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 2.1s"></circle>
      <circle
        class="chart-point"
        cx="375"
        cy="102"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 2.22s"></circle>
      <circle
        class="chart-point"
        cx="395"
        cy="122"
        r="3.2"
        fill="var(--ink)"
        style="animation-delay: 2.34s"></circle>
      <text
        x="210"
        y="305"
        text-anchor="middle"
        font-family="JetBrains Mono, monospace"
        font-size="8"
        letter-spacing="2"
        fill="var(--ink-mute)">FIG. I — A SYSTEM UNDER STATISTICAL CONTROL</text
      >
      <text
        x="12"
        y="150"
        text-anchor="middle"
        font-family="JetBrains Mono, monospace"
        font-size="8"
        letter-spacing="2"
        fill="var(--ink-mute)"
        transform="rotate(-90 12 150)">UNDERSTANDING</text
      >
      <text
        x="210"
        y="14"
        text-anchor="middle"
        font-family="JetBrains Mono, monospace"
        font-size="8"
        letter-spacing="2"
        fill="var(--ink-mute)">BOOKS READ — IN SEQUENCE</text
      >
      <text
        x="335"
        y="30"
        text-anchor="end"
        font-family="Fraunces, serif"
        font-size="10"
        font-style="italic"
        fill="var(--accent)">a special cause —</text
      >
      <text
        x="335"
        y="42"
        text-anchor="end"
        font-family="Fraunces, serif"
        font-size="10"
        font-style="italic"
        fill="var(--accent)">worth investigating</text
      >
    </svg>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    padding: 8rem 2.5rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    border-bottom: 1px solid var(--rule);
    max-width: 1400px;
    margin: 0 auto;
  }

  .hero::before {
    content: 'EST. — A SOCIETY FOR PROFOUND READING';
    position: absolute;
    top: 6rem;
    left: 2.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--ink-mute);
  }

  .hero-text {
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-eyebrow::before {
    content: '';
    width: 2.5rem;
    height: 1px;
    background: var(--accent);
  }

  h1.hero-title {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
    color: var(--ink);
  }

  h1.hero-title .italic {
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  .hero-tagline {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 1.3rem;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 32rem;
    margin-bottom: 2rem;
    padding-left: 1.5rem;
    border-left: 2px solid var(--accent);
  }

  .hero-meta {
    display: flex;
    gap: 3rem;
    margin-top: 3rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  .hero-meta-item .num {
    display: block;
    font-family: 'Fraunces', serif;
    font-size: 2.25rem;
    color: var(--ink);
    font-weight: 500;
    line-height: 1;
    margin-bottom: 0.35rem;
    font-style: italic;
  }

  .hero-meta-item .num.accent {
    color: var(--accent);
  }

  .hero-visual {
    position: relative;
    aspect-ratio: 1;
    max-width: 520px;
    margin: 0 auto;
    width: 100%;
    opacity: 0;
    animation: pbc-fade-up 1.2s ease 0.35s forwards;
  }

  .control-chart {
    width: 100%;
    height: 100%;
  }

  .hero-text > * {
    opacity: 0;
    animation: pbc-fade-up 0.9s ease forwards;
  }

  .hero-text > *:nth-child(1) {
    animation-delay: 0.15s;
  }

  .hero-text > *:nth-child(2) {
    animation-delay: 0.3s;
  }

  .hero-text > *:nth-child(3) {
    animation-delay: 0.45s;
  }

  .hero-text > *:nth-child(4) {
    animation-delay: 0.6s;
  }

  :global(.chart-process-line) {
    stroke-dasharray: 2000;
    stroke-dashoffset: 2000;
    animation: pbc-draw-line 2.5s ease 0.4s forwards;
  }

  :global(.chart-point) {
    opacity: 0;
    animation: pbc-point-appear 0.4s ease forwards;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 7rem;
    }

    .hero::before {
      display: none;
    }

    .hero-visual {
      max-width: 380px;
    }

    .hero-meta {
      flex-wrap: wrap;
      gap: 2rem;
    }
  }
</style>
